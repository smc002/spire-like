# Normalize line endings
* text=auto eol=lf

# Godot text resources stay LF
*.gd          text eol=lf
*.tscn        text eol=lf
*.tres        text eol=lf
*.godot       text eol=lf
*.cfg         text eol=lf
*.import      text eol=lf

# Binary assets
*.png         binary
*.jpg         binary
*.jpeg        binary
*.webp        binary
*.ogg         binary
*.wav         binary
*.mp3         binary
*.ttf         binary
*.otf         binary
